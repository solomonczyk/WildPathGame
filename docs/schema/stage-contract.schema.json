{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WildPathGame Stage Contract",
  "type": "object",
  "required": [
    "stage_id",
    "goal",
    "owner",
    "start_date",
    "deadline",
    "maximum_timebox_days",
    "planned_budget",
    "maximum_budget",
    "entry_criteria",
    "in_scope",
    "out_of_scope",
    "deliverables",
    "required_tests",
    "required_evidence",
    "kpi_thresholds",
    "zero_tolerance",
    "go_conditions",
    "hold_conditions",
    "pivot_conditions",
    "stop_conditions",
    "next_allowed_stage"
  ],
  "properties": {
    "stage_id": { "type": "string", "minLength": 3 },
    "goal": { "type": "string", "minLength": 10 },
    "owner": { "type": "string", "minLength": 2 },
    "start_date": { "type": "string", "format": "date" },
    "deadline": { "type": "string", "format": "date" },
    "maximum_timebox_days": { "type": "integer", "minimum": 1 },
    "planned_budget": { "type": "number", "minimum": 0 },
    "maximum_budget": { "type": "number", "minimum": 0 },
    "entry_criteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "in_scope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "out_of_scope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "deliverables": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "required_tests": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "required_evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "kpi_thresholds": { "type": "object", "minProperties": 1 },
    "zero_tolerance": { "type": "object", "minProperties": 1 },
    "go_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "hold_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "pivot_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "stop_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "next_allowed_stage": { "type": "string", "minLength": 2 }
  },
  "additionalProperties": false
}
