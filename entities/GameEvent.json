{
  "name": "GameEvent",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "danger",
        "opportunity",
        "weather",
        "encounter",
        "discovery"
      ]
    },
    "min_day": {
      "type": "number",
      "default": 1
    },
    "probability": {
      "type": "number",
      "default": 0.3
    },
    "choices": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "outcome_text": {
            "type": "string"
          },
          "health_delta": {
            "type": "number"
          },
          "hunger_delta": {
            "type": "number"
          },
          "thirst_delta": {
            "type": "number"
          },
          "energy_delta": {
            "type": "number"
          },
          "warmth_delta": {
            "type": "number"
          },
          "skill_required": {
            "type": "string"
          },
          "skill_bonus": {
            "type": "number"
          }
        }
      }
    },
    "knowledge_block": {
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "title",
    "description",
    "type"
  ]
}
